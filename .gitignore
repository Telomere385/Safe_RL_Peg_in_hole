# Training outputs
logs/
runs/
wandb/

# Ignore generated result artifacts by default, but keep model checkpoints
# trackable so trained policies can be committed.
results/*
!results/
!results/**/
!results/**/*.msh
!results/**/*.pt
!results/**/*.pth
!results/**/*.pkl
results/wandb/
results/wandb/**
results/SAC/
results/SAC/**

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.eggs/
dist/
build/

# Large asset files (store separately or use Git LFS)
*.usd
*.usda
*.usdc
*.usdz

# Track the bundled project USD assets kept under the repo.
!assets/usd/**/*.usd
!assets/usd/**/*.usda
!assets/usd/**/*.usdc
!assets/usd/**/*.usdz

# IDE
.vscode/
.idea/
*.swp

# Jupyter
.ipynb_checkpoints/

# OS
.DS_Store
Thumbs.db
